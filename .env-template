#
# Ollama stack configuration.
#
# This `.env` file is intentionally verbose: it documents the "why" behind each variable.
# The idea is to keep `docker-compose.yml` a mostly-static template, while `.env` contains
# all versions, ports, paths and runtime knobs (easy to audit and support later).
#

#
# Ollama (LLM server)
#

# Docker image tag for `ollama/ollama`.
# Pinning is recommended to avoid unexpected behavior changes after upgrades.
OLLAMA_VERSION=0.20.5

# Persistent models storage on the host.
# This path is bind-mounted into the container as `/root/.ollama` (see `OLLAMA_MODELS`).
OLLAMA_HOME=./data/ollama

# Container port where the Ollama HTTP API listens (inside docker network).
# Keep it 11434 unless you have a strong reason to change it.
OLLAMA_PORT_CONTAINER=11434

# Host port exposed for local tools (curl, IDEs, etc).
# Note: containers should not use 127.0.0.1:OLLAMA_PORT_LOCAL to reach Ollama unless they share host network.
OLLAMA_PORT_LOCAL=11434

# Default context window for the Ollama server.
# Why:
# - Ollama has a small default context window, and it can silently truncate long prompts.
# - Setting this provides a safe baseline for ALL clients (curl/open-webui/etc) that don't pass `options.num_ctx`.
# How it interacts with clients:
# - Per-request `options.num_ctx` (if a client passes it) should override this default for that request.
# Sizing guidance:
# - Start with 8192 or 16384, then increase if you have enough RAM/VRAM and need longer context.
OLLAMA_CONTEXT_LENGTH=16384

# Optional token for Open WebUI / HuggingFace integration.
# Keep private. Leave empty if you don't use features that require it.
# https://huggingface.co/settings/tokens/new?tokenType=read
OLLAMA_HF_TOKEN=

#
# SearXNG (metasearch)
#

# Docker image tag for `searxng/searxng`.
SEARXNG_VERSION=2026.4.13-ee66b070a

# Base URL used by the container (NOT the host URL).
SEARXNG_BASE_URL=http://searxng:8080/

# Secret key for SearXNG. Must be kept private.
SEARXNG_SECRET_KEY=

#
# Open WebUI
#

# Docker image tag for `ghcr.io/open-webui/open-webui`.
OPEN_WEBUI_VERSION=v0.8.12
